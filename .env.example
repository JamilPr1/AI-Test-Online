# Admin dashboard password (change in production)
ADMIN_PASSWORD=admin123

# Persistent storage — auto-configured on Vercel when you create a Blob store
# Local dev: run `npx vercel blob create-store ai-test-sessions --access private --yes`
BLOB_READ_WRITE_TOKEN=

# Optional: Turso/libSQL for local dev without Vercel Blob
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
