# Admin dashboard password (change in production)
ADMIN_PASSWORD=admin123

# Persistent database (required on Vercel — data survives redeployments)
# Sign up free at https://turso.tech then run:
#   turso db create ai-test-online
#   turso db show ai-test-online --url
#   turso db tokens create ai-test-online
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
